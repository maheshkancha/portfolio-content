{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Portfolio Schema",
    "type": "object",
    "required": [
        "profile",
        "skills",
        "experience",
        "projects"
    ],
    "properties": {
        "profile": {
            "type": "object",
            "required": [
                "name",
                "title",
                "summary"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "summary": {
                    "type": "string"
                },
                "location": {
                    "type": "string"
                },
                "yearsOfExperience": {
                    "type": "number",
                    "minimum": 0
                },
                "avatarUrl": {
                    "type": "string",
                    "format": "uri"
                }
            }
        },
        "skills": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "category",
                    "items"
                ],
                "properties": {
                    "category": {
                        "type": "string"
                    },
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "experience": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "company",
                    "role",
                    "startDate"
                ],
                "properties": {
                    "company": {
                        "type": "string"
                    },
                    "role": {
                        "type": "string"
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "endDate": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date"
                    },
                    "description": {
                        "type": "string"
                    },
                    "technologies": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "projects": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "name",
                    "description"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "techStack": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "repoUrl": {
                        "type": "string",
                        "format": "uri"
                    },
                    "liveUrl": {
                        "type": "string",
                        "format": "uri"
                    },
                    "imageUrl": {
                        "type": "string",
                        "format": "uri"
                    }
                }
            }
        },
        "domains": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "education": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "institution",
                    "degree"
                ],
                "properties": {
                    "institution": {
                        "type": "string"
                    },
                    "degree": {
                        "type": "string"
                    },
                    "year": {
                        "type": "number"
                    }
                }
            }
        },
        "social": {
            "type": "object",
            "properties": {
                "linkedin": {
                    "type": "string",
                    "format": "uri"
                },
                "github": {
                    "type": "string",
                    "format": "uri"
                },
                "twitter": {
                    "type": "string",
                    "format": "uri"
                }
            }
        }
    }
}